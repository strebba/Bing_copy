# ═══════════════════════════════════════════════════════════
# WAGMI Copy Trading Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ── BingX API ────────────────────────────────────────────────
# Get from BingX → Account → API Management
# Permissions required: Read + Trade (NO Withdraw)
BINGX_API_KEY=your_api_key_here
BINGX_API_SECRET=your_api_secret_here

# Set to true for paper trading (BingX demo environment)
DEMO_MODE=true

# ── Trading Configuration ─────────────────────────────────────
INITIAL_CAPITAL=2000.0
MAX_LEVERAGE=5
RISK_PER_TRADE=0.01
MAX_OPEN_POSITIONS=5
TRADING_PAIRS=BTC-USDT,ETH-USDT,SOL-USDT

# Strategy weights (must sum to 1.0)
STRATEGY_WEIGHT_ALPHA=0.4
STRATEGY_WEIGHT_BETA=0.3
STRATEGY_WEIGHT_GAMMA=0.3

# Profit sharing rate for copy traders (8-10%)
PROFIT_SHARING_RATE=0.10

# ── Telegram Alerting ──────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Database ───────────────────────────────────────────────────
POSTGRES_DSN=postgresql://wagmi:wagmi_secure_pwd@localhost:5432/wagmi_ct
POSTGRES_PASSWORD=wagmi_secure_pwd
REDIS_URL=redis://localhost:6379/0

# ── InfluxDB (optional, for time-series metrics) ───────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=wagmi
INFLUXDB_BUCKET=trading

# ── Monitoring ──────────────────────────────────────────────────
PROMETHEUS_PORT=8000

# ── Grafana ────────────────────────────────────────────────────
GRAFANA_PASSWORD=wagmi_grafana_pwd

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/wagmi_ct.log
